{
    "manifest_version": 3,
    "name":"Linkedin AdBlocker",
    "description": "Blocking ads.",
    "version":"1.0",
    "permissions":[
        "scripting",
        "activeTab",
        "tabs",
        "webNavigation",
        "contextMenus",
        "storage"
    ],
    "host_permissions":[
        "https://www.linkedin.com/*"
    ],
    "background":{
        "service_worker":"background.js",
        "type":"module"
    }
}